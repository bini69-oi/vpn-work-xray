# Получить у @BotFather
TELEGRAM_BOT_TOKEN=

# Проверка только Telegram, без vpn-productd (1 = не требовать VPN_PRODUCT_*)
# BOT_DRY_RUN=1

# Базовый URL vpn-productd (без завершающего слэша)
VPN_PRODUCT_BASE_URL=http://127.0.0.1:8080

# Тот же токен, что и VPN_PRODUCT_API_TOKEN на стороне сервера
VPN_PRODUCT_API_TOKEN=

# Опционально: профили для выдачи через запятую; пусто = дефолт сервера (например xui-test-vpn)
# VPN_PROFILE_IDS=xui-test-vpn

# Опционально: разрешённые Telegram user id через запятую; пусто = все пользователи
# ALLOWED_TELEGRAM_IDS=123456789,987654321

# Опционально: централизованные логи в Loki
# LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push
# LOKI_TAGS=service=telegram-bot,env=dev
# LOKI_USERNAME=
# LOKI_PASSWORD=
