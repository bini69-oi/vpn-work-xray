# Required API token for all /admin and /v1 endpoints.
VPN_PRODUCT_API_TOKEN=change-me-strong-token
VPN_PRODUCT_ADMIN_TOKEN=change-me-separate-admin-token
VPN_PRODUCT_ADMIN_ALLOWLIST=127.0.0.1,::1

# Canonical staging listener and state location.
VPN_PRODUCT_LISTEN=127.0.0.1:8080
VPN_PRODUCT_DATA_DIR=/var/lib/vpn-product
# Public base URL used in issued subscription links.
# Must be externally reachable (domain or sslip endpoint).
# VPN_PRODUCT_PUBLIC_BASE_URL=https://198-13-186-190.sslip.io
# Per-user simultaneous IP/device limit (anti-sharing).
# VPN_PRODUCT_LIMIT_IP=3
# Strict issue flow: abort/revoke link if apply/verification fails.
# VPN_PRODUCT_ISSUE_STRICT=true
# Optional separate business DB path (autoscale-ready prep).
# VPN_PRODUCT_DB_PATH=/var/lib/vpn-control/product.db

# Optional log file path (empty = stdout only).
VPN_PRODUCT_LOG_FILE=/var/log/vpn-product/vpn-productd.log

# Optional comma-separated deep-check targets for /v1/health.
# Default in code is only VPN_PRODUCT_LISTEN.
# VPN_PRODUCT_HEALTH_TARGETS=127.0.0.1:8080,127.0.0.1:10808

# Optional 3x-ui integration for apply-to-3xui endpoint.
# VPN_PRODUCT_3XUI_DB_PATH=/etc/x-ui/x-ui.db
# VPN_PRODUCT_3XUI_INBOUND_PORT=8443
