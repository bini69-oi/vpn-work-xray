### Remnawave Panel env (пример)
### Источник: https://docs.rw/docs/install/remnawave-panel/ и https://raw.githubusercontent.com/remnawave/backend/refs/heads/main/.env.sample

### APP ###
APP_PORT=3000
METRICS_PORT=3001

### API ###
# Possible values: max (all cores), number, -1 (all cores - 1)
# Docs: https://docs.rw/docs/install/environment-variables#scaling-api
API_INSTANCES=1

### DATABASE ###
# FORMAT: postgresql://{user}:{password}@{host}:{port}/{database}
DATABASE_URL="postgresql://postgres:postgres@remnawave-db:5432/postgres"

### REDIS ###
REDIS_SOCKET=/var/run/valkey/valkey.sock

### JWT ###
# CRITICAL: По задаче оставить пустыми строками.
# Генерация: openssl rand -hex 32
# (даёт hex-строку длиной 64 символа = 256 бит энтропии)
JWT_AUTH_SECRET=""
JWT_API_TOKENS_SECRET=""

### PANEL DOMAIN ###
# PANEL_DOMAIN используется в .env.sample. Оставляем плейсхолдер.
PANEL_DOMAIN=TODO

### FRONT_END ###
# Used by CORS (docs: https://docs.rw/docs/install/environment-variables#domains)
# Обычно ставят домен панели; можно оставить "*".
FRONT_END_DOMAIN=TODO

### SUBSCRIPTION PUBLIC DOMAIN (ОБЯЗАТЕЛЬНО) ###
# ВНИМАНИЕ: панель НЕ ЗАПУСТИТСЯ без реального значения здесь.
# Указывай домен БЕЗ схемы (не "https://") и БЕЗ слеша в конце.
# Пример: sub.example.com
# Used in UI/API for public subscription URL.
SUB_PUBLIC_DOMAIN=TODO

### METRICS (optional) ###
METRICS_USER=admin
METRICS_PASS=admin

### WEBHOOK (optional) ###
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-url.com/endpoint
WEBHOOK_SECRET_HEADER=

### Postgres container variables (used by docker-compose) ###
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

### Project placeholders (из задачи) ###
# PANEL_DOMAIN=TODO (например: panel.example.com)
# SUB_DOMAIN=TODO (например: sub.example.com)
# ADMIN_EMAIL=TODO
#
# NOTE: в Remnawave официально используется:
# - FRONT_END_DOMAIN (домен панели для CORS)
# - SUB_PUBLIC_DOMAIN (публичный URL подписки/страницы)
