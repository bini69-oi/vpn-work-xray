# Required API token for all /admin and /v1 endpoints.
VPN_PRODUCT_API_TOKEN=change-me-strong-token
VPN_PRODUCT_ADMIN_TOKEN=change-me-separate-admin-token
VPN_PRODUCT_ADMIN_ALLOWLIST=127.0.0.1,::1

# Canonical staging listener and state location.
VPN_PRODUCT_LISTEN=127.0.0.1:8080
VPN_PRODUCT_DATA_DIR=/var/lib/vpn-product
# Public base URL used in issued subscription links.
# Must be externally reachable (domain or sslip endpoint).
# VPN_PRODUCT_PUBLIC_BASE_URL=https://198-13-186-190.sslip.io
# Secret for AES-GCM storage of subscription token in DB (Mini App /admin/user/.../status subUrl). Generate a long random string.
# VPN_PRODUCT_SUBSCRIPTION_TOKEN_KEY=change-me-32bytes-or-longer-random
# Per-user simultaneous IP/device limit (anti-sharing).
# VPN_PRODUCT_LIMIT_IP=3
# Strict issue flow: abort/revoke link if apply/verification fails.
# VPN_PRODUCT_ISSUE_STRICT=true
# Optional separate business DB path (autoscale-ready prep).
# VPN_PRODUCT_DB_PATH=/var/lib/vpn-control/product.db

# Optional log file path (empty = stdout only).
VPN_PRODUCT_LOG_FILE=/var/log/vpn-product/vpn-productd.log

# Optional comma-separated deep-check targets for /v1/health.
# Default in code is only VPN_PRODUCT_LISTEN.
# VPN_PRODUCT_HEALTH_TARGETS=127.0.0.1:8080,127.0.0.1:10808

# Optional 3x-ui integration for apply-to-3xui endpoint.
# VPN_PRODUCT_3XUI_DB_PATH=/etc/x-ui/x-ui.db
# VPN_PRODUCT_3XUI_INBOUND_PORT=8443

# Routing preset for generated client config: empty (default) or ru_warp (RU direct + WARP for blocked lists).
# VPN_PRODUCT_ROUTING_PRESET=ru_warp
# VPN_PRODUCT_ROUTING_RULES_PATH=/var/lib/vpn-product/routing_rules.json
# VPN_PRODUCT_WARP_DOMAINS_PATH=/etc/vpn-product/warp_domains.json
# VPN_PRODUCT_WARP_ENV_FILE=/etc/vpn-product/warp.env
# WARP_MODE=wireguard
# WARP_MODE=socks
# WARP_SOCKS_ADDR=127.0.0.1:40000
# VPN_PRODUCT_GEODATA_DIR=/usr/local/x-ui/bin
# VPN_PRODUCT_SETUP_WARP_SCRIPT=/opt/vpn-product/src/deploy/scripts/setup_warp.sh

# Prometheus: /metrics on the main API listener (unauthenticated scrape path).
# Optional dedicated metrics-only listener (disables /metrics on the main server when set).
# VPN_PRODUCT_METRICS_LISTEN=0.0.0.0:9091
# METRICS_PORT=9091

# Xray gRPC API (StatsService) for live online user count — same host:port as in 3x-ui / xray config.api (often 127.0.0.1:10085).
# VPN_PRODUCT_XRAY_STATS_ADDR=127.0.0.1:10085
# VPN_PRODUCT_XRAY_API_ADDR=127.0.0.1:10085
# VPN_PRODUCT_XRAY_STATS_TIMEOUT=3s

# --- Happ client (https://www.happ.su/happ/dev-docs/app-management) ---
# Hide the "view/edit server JSON" UI in Happ (removes the > disclosure arrow
# and the raw Xray config page). Default: enabled.
# IMPORTANT: this is a Happ Advanced Parameter — it is only honoured for
# subscriptions that are bound to a Provider ID registered at happ.su.
# Without a Provider ID the header is sent but the client ignores it.
# VPN_PRODUCT_HAPP_HIDE_SETTINGS=1

# Optional Standard Parameters (work on any Happ install, no Provider ID needed).
# VPN_PRODUCT_HAPP_UPDATE_INTERVAL_HOURS=12
# VPN_PRODUCT_HAPP_SUPPORT_URL=https://t.me/your_support
# VPN_PRODUCT_HAPP_WEB_URL=https://your-site.example
# VPN_PRODUCT_HAPP_ANNOUNCE=base64:...  # or plain text, max 200 chars
