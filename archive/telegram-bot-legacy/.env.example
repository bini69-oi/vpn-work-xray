# Получить у @BotFather
TELEGRAM_BOT_TOKEN=

# Проверка без vpn-productd (1 = не требовать VPN_PRODUCT_*)
BOT_DRY_RUN=0

# HTTPS URL Mini App (тот же, что в WEBAPP_URL у telegram-miniapp; кнопка «Приложение» в меню)
TELEGRAM_MINIAPP_URL=

# Базовый URL vpn-productd (без завершающего слэша)
VPN_PRODUCT_BASE_URL=http://127.0.0.1:8080

# Тот же токен, что и VPN_PRODUCT_API_TOKEN на стороне сервера
VPN_PRODUCT_API_TOKEN=

# Профили для выдачи через запятую; пусто = дефолт сервера (например xui-test-vpn)
VPN_PROFILE_IDS=xui-test-vpn

# Whitelist пользователей (через запятую; пусто = все)
ALLOWED_TELEGRAM_IDS=

# Админы (через запятую; пусто = нет админских команд)
ADMIN_TELEGRAM_IDS=

# Rate limit на /subscribe в секундах
BOT_RATE_LIMIT_SECONDS=60

# Telegram Payments (если пусто — используется ручная оплата)
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=RUB
PAYMENT_PLANS=[{"months":1,"price_rub":150,"label":"1 месяц"},{"months":3,"price_rub":400,"label":"3 месяца"},{"months":6,"price_rub":700,"label":"6 месяцев"},{"months":12,"price_rub":1200,"label":"12 месяцев"}]
PAYMENT_MANUAL_DETAILS=

# Опционально: централизованные логи в Loki
LOKI_URL=
LOKI_TAGS=service=telegram-bot
LOKI_USERNAME=
LOKI_PASSWORD=
