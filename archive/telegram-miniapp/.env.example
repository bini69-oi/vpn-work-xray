# === Telegram ===
# Получи токен у @BotFather в Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# === VPN Product API ===
# URL твоего vpn-productd API (замени на публичный домен когда будет)
VPN_API_URL=http://localhost:8080
VPN_ADMIN_TOKEN=YOUR_ADMIN_TOKEN_HERE

# === Web App ===
# URL где будет хоститься Mini App (нужен HTTPS!)
# Для разработки можно использовать ngrok
WEBAPP_URL=https://your-domain.com

# === Server ===
PORT=3000

# === Optional ===
# 1 = включить polling этого же бота в Node (дублирует Python-бота — обычно не нужно)
# START_TELEGRAM_BOT_POLLING=0
