# Токен от @BotFather (можно вместо BOT_TOKEN указать TELEGRAM_BOT_TOKEN — как в archive/telegram-bot-legacy/)
BOT_TOKEN=replace-with-token-from-botfather

# Если не коннектится к api.telegram.org: HTTP(S) или SOCKS5 (зависимость aiohttp-socks в requirements.txt)
# TELEGRAM_PROXY=http://127.0.0.1:7890

# Список telegram user id админов (ADMIN_IDS или ADMIN_TELEGRAM_IDS как в legacy-боте)
ADMIN_IDS=

# Опционально: whitelist пользователей (пусто = все)
ALLOWED_TELEGRAM_IDS=

# URL vpn-productd: VPN_API_URL или VPN_PRODUCT_BASE_URL
VPN_API_URL=http://127.0.0.1:8080
# VPN_API_TOKEN или VPN_PRODUCT_API_TOKEN
VPN_API_TOKEN=

# Профили выдачи (через запятую), для новых подписок через API; пусто = xui-test-vpn
VPN_PROFILE_IDS=xui-test-vpn

# Локальная SQLite бота
DATABASE_PATH=data/bot.db

# Рефералы: +N дней за оплатившего друга
REFERRAL_BONUS_DAYS=15

# Ручная оплата (реквизиты текстом; для заявок админу при PAYMENT_STUB=0)
PAYMENT_MANUAL_DETAILS=

# HTTPS-страница оплаты СБП (кнопка «Перейти к оплате»). Пусто — заглушка с подсказкой.
# SBP_PAY_URL=https://example.com/pay

# Заглушка проверки «Я оплатил»: 1 = не слать заявку админу, показать текст-заглушку
# PAYMENT_STUB=0
# PAYMENT_STUB_RESULT=ok
# PAYMENT_STUB_RESULT=fail

# Telegram Payments (опционально)
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=RUB

# USDT (не используется в текущем сценарии СБП)
CRYPTO_WALLET_ADDRESS=

# @username без @ для ссылки «в поддержку»
SUPPORT_USERNAME=

# Имя бота без @ (для реф-ссылки; можно не задавать — возьмём из getMe)
BOT_USERNAME=
