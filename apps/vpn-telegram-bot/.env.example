# =============================================================================
# Telegram VPN bot — Remnawave only
# =============================================================================

# --- Telegram ---
# Token from @BotFather. Alias: TELEGRAM_BOT_TOKEN.
BOT_TOKEN=replace-with-token-from-botfather

# Bot username without @ (для реф-ссылки; можно не задавать — возьмём из getMe).
BOT_USERNAME=

# Telegram user ids администраторов через запятую.
ADMIN_IDS=

# Опциональный whitelist пользователей. Пусто = всем.
ALLOWED_TELEGRAM_IDS=

# HTTP(S)/SOCKS5 proxy до api.telegram.org (если сеть режет Telegram).
# TELEGRAM_PROXY=http://127.0.0.1:7890

# --- Remnawave Panel API (https://docs.rw) ---
# Публичный URL панели БЕЗ `/api` — клиент сам допишет путь.
REMNAWAVE_PANEL_URL=https://panel.example.com
# Токен из панели: Settings → API Tokens
REMNAWAVE_API_TOKEN=
# UUID внутренних squad через запятую (обязательно для создания пользователя
# через POST /api/users; без них бот сможет только продлевать существующих).
REMNAWAVE_INTERNAL_SQUAD_UUIDS=
# Если панель за Caddy с X-Api-Key
# REMNAWAVE_CADDY_TOKEN=

# --- Локальная SQLite бота (счётчики, рефералы, заявки на оплату) ---
DATABASE_PATH=data/bot.db

# --- Реферальная программа ---
REFERRAL_BONUS_DAYS=15

# --- Платежи ---
# Текстовые реквизиты для заявок админу при PAYMENT_STUB=0.
PAYMENT_MANUAL_DETAILS=

# HTTPS-страница оплаты СБП (кнопка «Перейти к оплате»). Пусто — заглушка.
# SBP_PAY_URL=https://example.com/pay

# Заглушка проверки «Я оплатил»: 1 = не слать заявку админу, показать текст-заглушку.
# PAYMENT_STUB=0
# PAYMENT_STUB_RESULT=ok
# PAYMENT_STUB_RESULT=fail

# Telegram Payments (опционально).
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=RUB

# USDT (не используется в текущем СБП-сценарии).
CRYPTO_WALLET_ADDRESS=

# --- Поддержка ---
# @username без @ для ссылки «в поддержку».
SUPPORT_USERNAME=
